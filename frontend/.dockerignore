# .dockerignore do contexto frontend/.
# A raiz já filtra .git, etc — aqui o foco é cortar node_modules
# (~200MB) que o Dockerfile reinstala via `npm install` durante o build.

node_modules
npm-debug.log
yarn-debug.log
yarn-error.log

# Builds locais (Dockerfile gera o seu via `npm run build`)
dist
.vite

# Env locais — em produção nginx serve estático, dev usa .env.local
.env
.env.local
.env.development
.env.production
*.local
!.env.example

# OS / IDE
.DS_Store
.vscode
.idea
